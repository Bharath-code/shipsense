# ShipSense — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Convex (required)
# Your Convex project URL — found in the Convex dashboard Settings tab.
PUBLIC_CONVEX_URL=

# GitHub OAuth (required — configured via @convex-dev/auth)
# Created at https://github.com/settings/developers under your OAuth App.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OpenRouter API (required for AI insights, issue classification, reply drafts)
# Free tier with automatic model fallback — get at https://openrouter.ai/keys
# Uses openrouter/free which auto-routes across Gemini, Claude, Mistral, etc.
OPENROUTER_API_KEY=

# Email (required for digest/reports)
# Resend API key — created at https://resend.com/api-keys
RESEND_API_KEY=

# Admin access — comma-separated Convex user IDs for development/full access
ADMIN_USER_IDS=

# Dodo Payments (required for billing)
# Created in your Dodo Payments dashboard
DODO_PAYMENTS_SECRET_KEY=
DODO_PAYMENTS_PRODUCT_ID=
